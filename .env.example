# === Server ===
REST_HOST=0.0.0.0
REST_PORT=8000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# === Models ===
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CLASSIFIER_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
SENTIMENT_MODEL=nlptown/bert-base-multilingual-uncased-sentiment
TOXICITY_MODEL=unitary/multilingual-toxic-xlm-roberta
TOXICITY_THRESHOLD=0.8

# === Qdrant Cache ===
QDRANT_COLLECTION=nlp_cache
QDRANT_CACHE_THRESHOLD=0.92

# === Observability ===
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=nlp-microservice
OTEL_EXPORTER_ENDPOINT=http://jaeger:4317
